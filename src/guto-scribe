#!/bin/bash
VENV_PYTHON="$HOME/.local/share/whisper-env/bin/python3"

if [ "$#" -eq 0 ]; then
    echo "❌ Uso: transcript [arquivo_de_audio]"
    exit 1
fi

FILE_PATH="$1"
# Pega o diretório do arquivo para salvar o resultado lá
DEST_DIR=$(dirname "$FILE_PATH")

echo "🚀 Iniciando transcrição de: $(basename "$FILE_PATH")"
echo "⚙️  Modelo: large-v3 | GPU (CUDA) | Idioma: Português (PT-BR)"

$VENV_PYTHON -m whisper_ctranslate2.whisper_ctranslate2 \
    "$FILE_PATH" \
    --model large-v3 \
    --device cuda \
    --compute_type float16 \
    --language pt \
    --output_dir "$DEST_DIR" \
    --output_format txt

echo "✅ Transcrição concluída! Arquivo salvo em: $DEST_DIR"
